{
  "name": "schoolwork-dashboard",
  "version": "0.3.3",
  "description": "Schoolwork — a desktop study planner for Senior Secondary students. Electron-packaged app with local accounts, per-term profiles, and Google Calendar sync.",
  "main": "main.js",
  "author": "Isaak Simpson",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64 -p never",
    "build:portable": "electron-builder --win portable --x64 -p never",
    "build:mac": "electron-builder --mac -p never"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "electron-updater": "^6.8.3",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "au.com.cudesign.schoolwork",
    "productName": "Schoolwork",
    "publish": [
      { "provider": "github", "owner": "isaakistarn", "repo": "Schoolwork" }
    ],
    "files": [
      "main.js",
      "preload.js",
      "google-calendar.js",
      "google-drive.js",
      "logo.ico",
      "PRIVACY.md",
      "TERMS.md",
      "supabase-config.json",
      "app/**/*",
      "!app/screenshots",
      "!app/scraps"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Schoolwork",
      "installerIcon": "logo.ico",
      "uninstallerIcon": "logo.ico",
      "installerHeaderIcon": "logo.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.education",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
